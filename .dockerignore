# Version control & editor noise (walking these kills Docker Desktop performance)
.git
**/.git
.gitignore
.cursor/
.vscode/
.idea/

# Local Python / Node (large trees)
.venv/
venv/
node_modules/
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/

# Tests & coverage
htmlcov/
.coverage
coverage.xml

# Build & runtime artifacts (host / legacy paths)
src/static/dist/
src/staticfiles/
src/media/
src/db.sqlite3
staticfiles/
media/
db.sqlite3
*.sqlite3-journal

# Secrets & local env (never bake into images)
.env

# Agent tooling / docs not needed in the image
.agents/
.planning/
.claude/
AGENTS.md
skills-lock.json
docs/

# Misc
.DS_Store
**/.DS_Store
*.map
README.md
presentation.md
licence.txt
