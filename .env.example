DJANGO_DEBUG=0
# With DEBUG=0, set SERVE_MEDIA=1 unless a reverse proxy serves /media/ (Docker Compose defaults to 1).
# SERVE_MEDIA=1
DJANGO_SECRET_KEY=REPLACE_WITH_openssl_rand_base64_48
ALLOWED_HOSTS=inkrise.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://inkrise.yourdomain.com

POSTGRES_DB=inkrise
POSTGRES_USER=inkrise
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# E-mail (réinitialisation de mot de passe). En dev, la console Django suffit souvent.
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# En production, exemple SMTP :
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=1
# DEFAULT_FROM_EMAIL=InkRise <noreply@yourdomain.com>
